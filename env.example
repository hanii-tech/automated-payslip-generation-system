# Copy this file to ".env" and fill in your real values.
# NEVER commit your actual .env file to version control.

# SMTP server settings (defaults below work for Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# The email address payslips will be sent FROM
SENDER_EMAIL=your_email@gmail.com

# For Gmail, this must be a 16-character "App Password", NOT your normal
# login password. Generate one at: https://myaccount.google.com/apppasswords
SENDER_PASSWORD=your_app_password_here
